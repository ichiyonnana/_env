        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
        -mi "Horizontal" ( "import maya.cmds as cmds\nimport maya.OpenMaya as om\n\ndef get_world_position(node):\n    \"\"\"Get the world position of a node.\"\"\"\n    return cmds.xform(node, query=True, worldSpace=True, translation=True)\n\ndef get_edge_vertices(edge):\n    \"\"\"Get the vertices of an edge.\"\"\"\n    return cmds.ls(cmds.polyListComponentConversion(edge, toVertex=True), flatten=True)\n\ndef dot_product(vector1, vector2):\n    \"\"\"Calculate the dot product of two vectors.\"\"\"\n    return sum(v1*v2 for v1, v2 in zip(vector1, vector2))\n\n# Get the selected edges\nselected_edges = cmds.ls(selection=True, flatten=True)\n\n# Initialize an empty list to store the edges to select\nedges_to_select = []\n\n# Iterate over the selected edges\nfor edge in selected_edges:\n    # Get the vertices of the edge\n    vertices = get_edge_vertices(edge)\n\n    # Get the world positions of the vertices\n    world_positions = [get_world_position(vertex) for vertex in vertices]\n\n    # Calculate the vector from the start to the end of the edge\n    edge_vector = [end - start for start, end in zip(*world_positions)]\n\n    # Calculate the dot product of the edge vector and the world Y vector\n    dot_product_value = dot_product(edge_vector, [0, 1, 0])\n\n    # If the absolute value of the dot product is less than or equal to 0.5, add the edge to the list of edges to select\n    if abs(dot_product_value) < 0.5:\n        edges_to_select.append(edge)\n\n# Select the edges\ncmds.select(edges_to_select)" )
        -mip 0
        -mi "Vertical" ( "import maya.cmds as cmds\nimport maya.OpenMaya as om\n\ndef get_world_position(node):\n    \"\"\"Get the world position of a node.\"\"\"\n    return cmds.xform(node, query=True, worldSpace=True, translation=True)\n\ndef get_edge_vertices(edge):\n    \"\"\"Get the vertices of an edge.\"\"\"\n    return cmds.ls(cmds.polyListComponentConversion(edge, toVertex=True), flatten=True)\n\ndef dot_product(vector1, vector2):\n    \"\"\"Calculate the dot product of two vectors.\"\"\"\n    return sum(v1*v2 for v1, v2 in zip(vector1, vector2))\n\n# Get the selected edges\nselected_edges = cmds.ls(selection=True, flatten=True)\n\n# Initialize an empty list to store the edges to select\nedges_to_select = []\n\n# Iterate over the selected edges\nfor edge in selected_edges:\n    # Get the vertices of the edge\n    vertices = get_edge_vertices(edge)\n\n    # Get the world positions of the vertices\n    world_positions = [get_world_position(vertex) for vertex in vertices]\n\n    # Calculate the vector from the start to the end of the edge\n    edge_vector = [end - start for start, end in zip(*world_positions)]\n\n    # Calculate the dot product of the edge vector and the world Y vector\n    dot_product_value = dot_product(edge_vector, [0, 1, 0])\n\n    # If the absolute value of the dot product is less than or equal to 0.5, add the edge to the list of edges to select\n    if abs(dot_product_value) > 0.5:\n        edges_to_select.append(edge)\n\n# Select the edges\ncmds.select(edges_to_select)" )
        -mip 1
    ;
