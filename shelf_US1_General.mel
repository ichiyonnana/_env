        -commandRepeatable 1
        -flat 1
        -mi "to Joint" ( "import maya.cmds as cmds\n\ndef get_joint_depth(joint):\n    return joint.count('|')\n\ndef snap_joints_to_nearest_mesh_vertex():\n    sels = cmds.ls(selection=True, long=True)\n    joints = [s for s in sels if cmds.nodeType(s) == \"joint\"]\n    meshes = []\n    for s in sels:\n        if cmds.nodeType(s) == \"transform\":\n            shapes = cmds.listRelatives(s, shapes=True, type=\"mesh\", fullPath=True)\n            if shapes:\n                meshes.append(s)\n    if not joints or not meshes:\n        return\n    mesh = meshes[0]\n    vtxs = cmds.ls(mesh + \".vtx[*]\", flatten=True)\n    vtx_pos = [cmds.pointPosition(v, world=True) for v in vtxs]\n    joints = sorted(joints, key=get_joint_depth)\n    for j in joints:\n        jpos = cmds.xform(j, q=True, ws=True, t=True)\n        min_idx = min(range(len(vtx_pos)), key=lambda i: ((vtx_pos[i][0]-jpos[0])**2 + (vtx_pos[i][1]-jpos[1])**2 + (vtx_pos[i][2]-jpos[2])**2))\n        cmds.xform(j, ws=True, t=vtx_pos[min_idx])\n\ndef snap_mesh_vertices_to_nearest_joint():\n    sels = cmds.ls(selection=True, long=True)\n    joints = [s for s in sels if cmds.nodeType(s) == \"joint\"]\n    meshes = []\n    for s in sels:\n        if cmds.nodeType(s) == \"transform\":\n            shapes = cmds.listRelatives(s, shapes=True, type=\"mesh\", fullPath=True)\n            if shapes:\n                meshes.append(s)\n    if not joints or not meshes:\n        return\n    mesh = meshes[0]\n    vtxs = cmds.ls(mesh + \".vtx[*]\", flatten=True)\n    joint_pos = [cmds.xform(j, q=True, ws=True, t=True) for j in joints]\n    for v in vtxs:\n        vpos = cmds.pointPosition(v, world=True)\n        min_idx = min(range(len(joint_pos)), key=lambda i: ((joint_pos[i][0]-vpos[0])**2 + (joint_pos[i][1]-vpos[1])**2 + (joint_pos[i][2]-vpos[2])**2))\n        cmds.xform(v, ws=True, t=joint_pos[min_idx])\n\nsnap_mesh_vertices_to_nearest_joint()" )
        -mip 0
        -mi "to Mesh" ( "import maya.cmds as cmds\n\ndef get_joint_depth(joint):\n    return joint.count('|')\n\ndef snap_joints_to_nearest_mesh_vertex():\n    sels = cmds.ls(selection=True, long=True)\n    joints = [s for s in sels if cmds.nodeType(s) == \"joint\"]\n    meshes = []\n    for s in sels:\n        if cmds.nodeType(s) == \"transform\":\n            shapes = cmds.listRelatives(s, shapes=True, type=\"mesh\", fullPath=True)\n            if shapes:\n                meshes.append(s)\n    if not joints or not meshes:\n        return\n    mesh = meshes[0]\n    vtxs = cmds.ls(mesh + \".vtx[*]\", flatten=True)\n    vtx_pos = [cmds.pointPosition(v, world=True) for v in vtxs]\n    joints = sorted(joints, key=get_joint_depth)\n    for j in joints:\n        jpos = cmds.xform(j, q=True, ws=True, t=True)\n        min_idx = min(range(len(vtx_pos)), key=lambda i: ((vtx_pos[i][0]-jpos[0])**2 + (vtx_pos[i][1]-jpos[1])**2 + (vtx_pos[i][2]-jpos[2])**2))\n        cmds.xform(j, ws=True, t=vtx_pos[min_idx])\n\ndef snap_mesh_vertices_to_nearest_joint():\n    sels = cmds.ls(selection=True, long=True)\n    joints = [s for s in sels if cmds.nodeType(s) == \"joint\"]\n    meshes = []\n    for s in sels:\n        if cmds.nodeType(s) == \"transform\":\n            shapes = cmds.listRelatives(s, shapes=True, type=\"mesh\", fullPath=True)\n            if shapes:\n                meshes.append(s)\n    if not joints or not meshes:\n        return\n    mesh = meshes[0]\n    vtxs = cmds.ls(mesh + \".vtx[*]\", flatten=True)\n    joint_pos = [cmds.xform(j, q=True, ws=True, t=True) for j in joints]\n    for v in vtxs:\n        vpos = cmds.pointPosition(v, world=True)\n        min_idx = min(range(len(joint_pos)), key=lambda i: ((joint_pos[i][0]-vpos[0])**2 + (joint_pos[i][1]-vpos[1])**2 + (joint_pos[i][2]-vpos[2])**2))\n        cmds.xform(v, ws=True, t=joint_pos[min_idx])\n\nsnap_joints_to_nearest_mesh_vertex()" )
        -mip 1
