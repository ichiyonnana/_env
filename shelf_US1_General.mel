        -command "import maya.cmds as cmds\nimport maya.api.OpenMaya as om2\n\ndef get_uv_shell_count(mesh_name):\n    slist = om2.MGlobal.getSelectionListByName(mesh_name)\n    dag = slist.getDagPath(0)\n    fn_mesh = om2.MFnMesh(dag)\n\n    uv_shell_ids = om2.MIntArray()\n    uv_shell_ids = fn_mesh.getUvShellsIds()\n\n    return uv_shell_ids[0]\n\nprint(\"mesh:\", len(cmds.ls(selection=True, type=\"mesh\")))\nprint(\"joint: \", len(cmds.ls(selection=True, type=\"joint\")))\n\n\nsum = 0\nfor obj in cmds.ls(selection=True, type=\"mesh\"):\n    sum += get_uv_shell_count(obj)\n    \nprint(\"UV Shell: \", sum)" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
