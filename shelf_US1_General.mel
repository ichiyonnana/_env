        -mip 10
        -mi "Shorten imageplane path" ( "import re\nimport maya.cmds as cmds\n\nips = cmds.ls(type=\"imagePlane\")\n\nfor ip in ips:\n    current_src = cmds.getAttr(f\"{ip}.imageName\")\n    new_src = re.sub(r\"^.*(?=images)\", \"\", current_src)\n    cmds.setAttr(f\"{ip}.imageName\", new_src, type=\"string\")" )
