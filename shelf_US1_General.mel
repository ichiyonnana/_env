        -command "import re\nimport math\n\nimport maya.cmds as cmds\nimport maya.mel as mel\nimport maya.api.OpenMaya as om\n\nedges = cmds.ls(selection=True, flatten=True)\nborder_edges = []\n\nfor edge in edges:\n    vts = cmds.polyListComponentConversion(edge, tv=True)\n\n    x1, y1, z1, x2, y2, z2 = cmds.xform(vts, q=True, translation=True, worldSpace=True)\n\n    if math.isclose(y1, 0) and math.isclose(y2, 0):\n        border_edges.append(edge)\n\ncmds.select(border_edges)" 
