        -command "import maya.cmds as cmds\n\nproxy_obj_name = \"jlproxyobj\"\n\nall_joints = [x for x in cmds.ls(type=\"joint\") if \":\" not in x]\npositions = [cmds.xform(x, q=True, translation=True, worldSpace=True) for x in all_joints]\n\nobj_name, shape = cmds.polyCreateFacet(ch=True, tx=1, s=1, p=[coord for pos in positions for coord in pos])\nobj = obj_name\n\ncmds.setAttr(f\"{obj}.overrideEnabled\", 1)\ncmds.setAttr(f\"{obj}.overrideShading\", 0)\ncmds.setAttr(f\"{obj}.overrideTexturing\", 0)\ncmds.setAttr(f\"{obj}.overridePlayback\", 0)\n\ncmds.rename(obj, proxy_obj_name)" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
