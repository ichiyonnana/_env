        -mip 13
        -mi "Filter Intermediate Mesh" ( "import maya.cmds as cmds\n\ndef hide_intermediate_meshes():\n    # āüābāVāģāmü[āhé╠é▌é­æIæ­\n    selected_nodes = cmds.ls(selection=True, dag=True, type=\"mesh\")\n    if not selected_nodes:\n        print(\"æIæ­Æåé╠āüābāVāģé¬éĀéĶé▄é╣é±üB\")\n        return\n\n    # intermediateObject é¬ 1 é╠āüābāVāģé╠é▌é­æIæ­\n    intermediate_meshes = [\n        mesh for mesh in selected_nodes if cmds.getAttr(f\"{mesh}.intermediateObject\")\n    ]\n    if not intermediate_meshes:\n        print(\"ÆåŖįāIāuāWāFāNāgé╠āüābāVāģé¬éĀéĶé▄é╣é±üB\")\n        return\n\n    # æIæ­é­ŹXÉV\n    cmds.select(intermediate_meshes)\n    print(f\"æIæ­é│éĻéĮÆåŖįāIāuāWāFāNāgāüābāVāģ: {intermediate_meshes}\")\n\n# Ä└Źs\nhide_intermediate_meshes()\n" )
        -mip 14
        -mi "Parent with Sel Order" ( "import maya.cmds as cmds\n\nobjs = cmds.ls(selection=True, long=True)\nfor i in range(len(objs)-1, 0, -1):\n    cmds.parent(objs[i], objs[i-1])" )
