        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\nimport maya.mel as mel\n\n\ndef set_paint_color(color):\n    if color == 'Rd':\n        cmds.art3dPaintCtx(\"art3dPaintContext\", e=True, rgbcolor=(1,0,0))\n    elif color == 'Gr':\n        cmds.art3dPaintCtx(\"art3dPaintContext\", e=True, rgbcolor=(0,1,0))\n    elif color == 'Bl':\n        cmds.art3dPaintCtx(\"art3dPaintContext\", e=True, rgbcolor=(0,0,1))\n    elif color == 'Wh':\n        cmds.art3dPaintCtx(\"art3dPaintContext\", e=True, rgbcolor=(1,1,1))\n    elif color == 'Bk':\n        cmds.art3dPaintCtx(\"art3dPaintContext\", e=True, rgbcolor=(0,0,0))\n\n\ndef set_tool_3dpaint():\n\tmel.eval(\"Art3dPaintToolOptions\")\n\n\ndef tilt_camera(*args):\n    active_panerl = cmds.getPanel(withFocus=True)\n    active_camera = cmds.modelPanel(active_panerl, query=True, camera=True)\n    tilt_value = cmds.floatSlider(\"tilt_slider\", query=True, value=True)\n    cmds.setAttr(active_camera + \".rotateZ\", tilt_value)\n\n\ndef reset_tilt(*args):\n    active_panel = cmds.getPanel(withFocus=True)\n    active_camera = cmds.modelPanel(active_panel, query=True, camera=True)\n    cmds.setAttr(active_camera + \".rotateZ\", 0)\n    cmds.floatSlider(\"tilt_slider\", edit=True, value=0)\n\n\ndef create_window():\n    window_name = 'color_selector'\n    if cmds.window(window_name, exists=True):\n        cmds.deleteUI(window_name, window=True)\n\n    window = cmds.window(window_name, title=\"Color Selector\", resizeToFitChildren=True, sizeable=False, maximizeButton=False, minimizeButton=False)\n    cmds.columnLayout(adjustableColumn=True)\n\n    cmds.rowLayout(numberOfColumns=10)\n    cmds.button(label='3DPaint', width=60, height=60, command=lambda x: set_tool_3dpaint())\n    cmds.button(label='Rd', width=60, height=60, command=lambda x: set_paint_color('Rd'))\n    cmds.button(label='Gr', width=60, height=60, command=lambda x: set_paint_color('Gr'))\n    cmds.button(label='Bl', width=60, height=60, command=lambda x: set_paint_color('Bl'))\n    cmds.button(label='Wh', width=60, height=60, command=lambda x: set_paint_color('Wh'))\n    cmds.button(label='Bk', width=60, height=60, command=lambda x: set_paint_color('Bk'))\n    cmds.setParent('..')\n    \n    cmds.rowLayout(numberOfColumns=10)\n    cmds.floatSlider(\"tilt_slider\", min=-360, max=360, value=0, width=300, height=30, dragCommand=tilt_camera)\n    cmds.button(label=\"Reset\", command=reset_tilt)\n    cmds.setParent('..')\n\n    cmds.showWindow(window)\n\ncreate_window()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
