        -command "import maya.cmds as cmds\nimport maya.api.OpenMaya as om\n\ndef hierarchy_depth(obj_name):\n    return cmds.ls(obj_name, long=True)[0].count(\"|\")\n\nproxy_obj_name = \"jlproxyobj\"\n\nsel = om.MSelectionList()\nsel.add(cmds.listRelatives(proxy_obj_name, shapes=True)[0])\nfn_mesh = om.MFnMesh(sel.getDagPath(0))\npositions = fn_mesh.getPoints(om.MSpace.kWorld)\n\nall_joints = [x for x in cmds.ls(type=\"joint\") if \":\" not in x]\n\njoint_pos_table = {}\n\nfor i in range(len(all_joints)):\n    joint_pos_table[all_joints[i]] = positions[i]\n\nall_joints.sort(key=lambda x: hierarchy_depth(x))\n\nfor joint in all_joints:\n    p = joint_pos_table[joint]\n    cmds.xform(joint, translation=[p.x, p.y, p.z], worldSpace=True)\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
