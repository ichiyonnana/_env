        -command "import maya.cmds as cmds\n\njoint_data_store = {}\n\ndef store_joint_data(*args):\n    global joint_data_store\n    joint_data_store = {}  # ÅēŖ·ē╗\n\n    joints = cmds.ls(type=\"joint\")\n    for jnt in joints:\n        translate = cmds.getAttr(f\"{jnt}.translate\")[0]\n        orient = cmds.getAttr(f\"{jnt}.jointOrient\")[0]\n        joint_data_store[jnt] = {\n            \"translate\": translate,\n            \"orient\": orient\n        }\n    cmds.inViewMessage(amg='[Store] Store Joints Tra & Ori', pos='topCenter', fade=True)\n\ndef restore_joint_data(*args):\n    global joint_data_store\n\n    for jnt, data in joint_data_store.items():\n        if cmds.objExists(jnt):\n            cmds.setAttr(f\"{jnt}.translate\", *data[\"translate\"])\n            cmds.setAttr(f\"{jnt}.jointOrient\", *data[\"orient\"])\n    cmds.inViewMessage(amg='[Restore] Restore Joints Tra & Ori', pos='topCenter', fade=True)\n\n# UI\ndef create_ui():\n    if cmds.window(\"jointStoreWin\", exists=True):\n        cmds.deleteUI(\"jointStoreWin\")\n\n    cmds.window(\"jointStoreWin\", title=\"Joint Store/Restore\", widthHeight=(200, 80))\n    cmds.columnLayout(adjustableColumn=True, rowSpacing=10, columnAlign=\"center\")\n    cmds.button(label=\"Store\", command=store_joint_data, height=30)\n    cmds.button(label=\"Restore\", command=restore_joint_data, height=30)\n    cmds.showWindow(\"jointStoreWin\")\n\ncreate_ui()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
