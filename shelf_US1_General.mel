        -marginHeight 1
        -command "import maya.cmds as cmds\n\nselected = cmds.ls(selection=True)\n\nlocator = cmds.spaceLocator()[0]\n\nif selected:\n\tcmds.parent(locator, selected[0])\t\n\tcmds.xform(locator, translation=(0, 0, 0), rotation=(0, 0, 0), scale=(1, 1, 1), objectSpace=True)\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 91
        -height 20
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "User Script" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Create Loc On Face" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "commandButton.png" 
        -image1 "commandButton.png" 
        -style "textOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\nimport maya.OpenMaya as om\n\ndef create_locators_on_faces():\n    sel_faces = cmds.ls(selection=True, flatten=True)  # æIæ­éĄéĮātāFü[āXé­ÄµōŠ\n    if not sel_faces:\n        cmds.warning(\"ātāFü[āXé­æIæ­éĄé─éŁéŠé│éóüB\")\n        return\n    \n    for face in sel_faces:\n        # ātāFü[āXé╠É┌É³ŗ¾ŖįüiTangent, Bitangent, NormalüjéŲÆåÉSŹ└ĢWé­ÄµōŠ\n        tangent, bitangent, normal, center = get_face_tangent_space_and_center(face)\n        \n        if tangent and bitangent and normal and center:\n            # āŹāPü[ā^ü[é­ŹņÉ¼éĄüAātāFü[āXé╠ÆåÉSé╔özÆu\n            loc = cmds.spaceLocator()[0]\n            cmds.xform(loc, translation=center, worldSpace=True)\n            \n            # āŹāPü[ā^ü[é╠āÅü[āŗāhā}āgāŖāNāXé­É▌ÆĶ\n            set_locator_matrix(loc, tangent, bitangent, normal, center)\n\ndef get_face_tangent_space_and_center(face):\n    \"\"\"æSÆĖō_é╠ĢĮŗŽé®éńÉ┌É³üiTangentüjüAÅ]¢@É³üiBitangentüjüA¢@É³üiNormalüjüAÆåÉSŹ└ĢWé­ÄµōŠ\"\"\"\n    sel_list = om.MSelectionList()\n    sel_list.add(face)\n    \n    dag_path = om.MDagPath()\n    component = om.MObject()\n    sel_list.getDagPath(0, dag_path, component)\n    \n    if not component.hasFn(om.MFn.kMeshPolygonComponent):\n        return None, None, None, None\n    \n    mesh_fn = om.MFnMesh(dag_path)\n    face_iter = om.MItMeshPolygon(dag_path, component)\n    \n    while not face_iter.isDone():\n        # ātāFü[āXé╠ÆåÉSŹ└ĢW\n        center = face_iter.center(om.MSpace.kWorld)\n        center_pos = [center.x, center.y, center.z]\n        \n        # ¢@É³é­ÄµōŠ\n        normal = om.MVector()\n        face_iter.getNormal(normal, om.MSpace.kWorld)\n        normal_vec = [normal.x, normal.y, normal.z]\n        \n        # ātāFü[āXé╠æSÆĖō_é╠ UV āxü[āXé╠É┌É³üEÅ]¢@É³é­ÄµōŠéĄüAĢĮŗŽé­īvÄZ\n        vertex_list = om.MIntArray()\n        face_iter.getVertices(vertex_list)\n        \n        if vertex_list.length() == 0:\n            return None, None, None, None\n        \n        tangent_sum = om.MVector(0, 0, 0)\n        bitangent_sum = om.MVector(0, 0, 0)\n        \n        for vtx_id in vertex_list:\n            tangent = om.MVector()\n            bitangent = om.MVector()\n            mesh_fn.getFaceVertexTangent(face_iter.index(), vtx_id, tangent, om.MSpace.kWorld)\n            mesh_fn.getFaceVertexBinormal(face_iter.index(), vtx_id, bitangent, om.MSpace.kWorld)\n            \n            tangent_sum += tangent\n            bitangent_sum += bitangent\n        \n        # ĢĮŗŽāxāNāgāŗé­īvÄZüiÉ│ŗKē╗éÓÄ└Ä{üj\n        tangent_avg = tangent_sum.normal()\n        bitangent_avg = bitangent_sum.normal()\n        \n        tangent_vec = [tangent_avg.x, tangent_avg.y, tangent_avg.z]\n        bitangent_vec = [bitangent_avg.x, bitangent_avg.y, bitangent_avg.z]\n        \n        return tangent_vec, bitangent_vec, normal_vec, center_pos\n    \n    return None, None, None, None\n\ndef set_locator_matrix(locator, tangent, bitangent, normal, position):\n    \"\"\"āŹāPü[ā^ü[é╠āÅü[āŗāhā}āgāŖāNāXé­É▌ÆĶ\"\"\"\n    matrix = [\n        tangent[0], tangent[1], tangent[2], 0,  # XÄ▓üiÉ┌É³üj\n        bitangent[0], bitangent[1], bitangent[2], 0,  # YÄ▓üiÅ]¢@É³üj\n        normal[0], normal[1], normal[2], 0,  # ZÄ▓üi¢@É³üj\n        position[0], position[1], position[2], 1  # ł╩Æu\n    ]\n    \n    cmds.xform(locator, matrix=matrix, worldSpace=True)\n\n# āXāNāŖāvāgÄ└Źs\ncreate_locators_on_faces()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
