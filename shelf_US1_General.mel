        -command "import maya.cmds as cmds\n\ntss_node = \"tripleShadingSwitch1\"\n\nselections = cmds.ls(selection=True, flatten=True, type=\"mesh\")\n\nfor i, mesh_node in enumerate(selections):\n    print(mesh_node)\n    fullpath = cmds.ls(mesh_node, long=True)[0]\n    print(fullpath)\n    \n    if \"body\" in fullpath:\n        file_node = \"file_pt_body_mask\"\n    elif \"hair\" in fullpath:\n        file_node = \"file_pt_hair_mask\"\n    elif \"face\" in fullpath:\n        file_node = \"file_pt_face_mask\"\n    else:\n        print(\"skip\")\n        continue\n        \n    try:\n        cmds.connectAttr(mesh_node + \".instObjGroups[0]\", tss_node + \".input[%s].inShape\" % i, force=True)\n        cmds.connectAttr(file_node + \".outColor\", tss_node + \".input[%s].inTriple\" % i, force=True)\n        \n    except:\n        pass\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
