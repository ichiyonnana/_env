        -command "import maya.cmds as cmds\nimport maya.api.OpenMaya as om\n\nfor trs_node in cmds.ls(selection=True):\n    shape_node = cmds.listRelatives(trs_node, shapes=True)[0]\n\n    cmds.setAttr(f\"{trs_node}.rotatePivot\", 0, 0, 0)\n    cmds.setAttr(f\"{trs_node}.scalePivot\", 0, 0, 0)\n\n    trs_pos = om.MVector(*cmds.getAttr(f\"{trs_node}.translate\")[0])\n    local_pos = om.MVector(*cmds.getAttr(f\"{shape_node}.localPosition\")[0])\n    cmds.setAttr(f\"{shape_node}.localPosition\", 0, 0, 0)\n    result = trs_pos + local_pos\n    cmds.setAttr(f\"{trs_node}.translate\", result.x, result.y, result.z)\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
