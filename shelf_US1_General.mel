        -command "import maya.cmds as cmds\n\ngroup_parts_nodes = cmds.ls(\"*\", type=\"groupParts\")\ngp_to_delete = []\n\nfor gp in group_parts_nodes:\n    neighbors = cmds.listConnections(destination=True, source=True)\n    \n    if neighbors and all([cmds.objectType(x, isType=\"groupParts\") or cmds.objectType(x, isType=\"nodeGraphEditorInfo\") for x in neighbors]):\n        gp_to_delete.append(gp)\n\ncmds.delete(gp_to_delete)" 
