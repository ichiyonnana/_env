        -command "import maya.cmds as cmds\nimport maya.mel as mel\n\n# æIæ­é│éĻéĮāüābāVāģé­ÄµōŠ\nselected_objects = cmds.ls(selection=True, long=True)\nif not selected_objects:\n    raise Exception(\"āIāuāWāFāNāgé¬æIæ­é│éĻé─éóé▄é╣é±üB\")\n\n# æIæ­é│éĻéĮŹ┼Åēé╠āIāuāWāFāNāgé­ÄgŚp\nselected_mesh = selected_objects[0]\n\n# āXāLāōāNāēāXā^é­ÄµōŠ\nskin_clusters = mel.eval('findRelatedSkinCluster \"{}\"'.format(selected_mesh))\nif not skin_clusters:\n    raise Exception(\"āXāLāōāNāēāXā^é¬ī®é┬é®éĶé▄é╣é±é┼éĄéĮüB\")\n\n# ÆĖō_é╠āEāFāCāgé­ÄµōŠéĄé─āRāsü[\nvertex_count = cmds.polyEvaluate(selected_mesh, vertex=True)\nfor i in range(vertex_count):\n    vertex_name = \"{}.vtx[{}]\".format(selected_mesh, i)\n    position = cmds.pointPosition(vertex_name, local=True)\n    \n    # X+æżé╠ÆĖō_é╠é▌ÅłŚØ\n    if position[0] > 0:\n        # æ╬ē×éĘéķX-æżé╠ÆĖō_é­ī®é┬é»éķ\n        mirror_position = (-position[0], position[1], position[2])\n        \n        # āgāīāēāōāXé­ŹlŚČéĄé─X-æżé╠ÆĖō_é­ī¤Ź§\n        for j in range(vertex_count):\n            target_vertex_name = \"{}.vtx[{}]\".format(selected_mesh, j)\n            target_position = cmds.pointPosition(target_vertex_name, local=True)\n            \n            if (abs(target_position[0] - mirror_position[0]) < 0.001 and\n                abs(target_position[1] - mirror_position[1]) < 0.001 and\n                abs(target_position[2] - mirror_position[2]) < 0.001):\n                # āEāFāCāgé­ÄµōŠéĄé─āRāsü[\n                weights = cmds.skinPercent(skin_clusters, vertex_name, query=True, value=True)\n                cmds.skinPercent(skin_clusters, target_vertex_name, transformValue=[(weight, val) for weight, val in zip(cmds.skinPercent(skin_clusters, vertex_name, query=True, transform=None), weights)])\n                break" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
