	-commandLanguage "mel"
	-command ("string $ret = `promptDialog\n        -title \"create new layer\"\n        -message \"Enter Name:\"\n\t\t-tx \"ly_\"\n        -button \"OK\"\n        -button \"Cancel\"\n        -defaultButton \"OK\"\n        -cancelButton \"Cancel\"\n        -dismissString \"Cancel\"`;\n        \nif ($ret == \"OK\") {\n    $newLayerName = `promptDialog -query -text`;\n\tcreateDisplayLayer -name ($newLayerName) -nr;\n}")
	create_layer;

