runTimeCommand
	-label ""
	-annotation ""
	-longAnnotation ""
	-category "Custom Scripts"
	-image ""
	-tags ""
	-keywords ""
	-plugin ""
	-helpUrl ""
	-hotkeyCtx ""
	-commandLanguage "python"
	-command ("from maya import cmds\n\ncurrent_context = cmds.currentCtx()\n\nif current_context == \"art3dPaintContext\":\n    current_mode = cmds.art3dPaintCtx(current_context, q=True, reflection=True)\n    new_mode = not current_mode\n    cmds.art3dPaintCtx(cmds.currentCtx(), e=True, reflection=new_mode)\n    \n    cmds.inViewMessage(smg=\"Reflection %s\"%new_mode, pos=\"topCenter\", bkc=\"0x00000000\", fade=True)\n\nelse:\n    current_mode = cmds.symmetricModelling(q=True, symmetry=True)\n    new_mode = not current_mode\n    cmds.symmetricModelling(symmetry=new_mode)\n    \n    cmds.inViewMessage(smg=\"Symmetry %s\"%new_mode, pos=\"topCenter\", bkc=\"0x00000000\", fade=True)\n    ")
	Toggle_Symmetry;

